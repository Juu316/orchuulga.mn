u043d \u0442\u0443\u0440\u0448\u043b\u0430\u0433\u0430, \u043d\u0430\u0441 \u0431\u043e\u043b\u043e\u043d \u0434\u0430\u0441\u0430\u043d \u0437\u043e\u0445\u0438\u0446\u043e\u0445 \u0447\u0430\u0434\u0432\u0430\u0440 \u0437\u044d\u0440\u044d\u0433 \u04af\u0437\u04af\u04af\u043b\u044d\u043b\u0442\u04af\u04af\u0434\u0438\u0439\u0433 \u0445\u0430\u0440\u0433\u0430\u043b\u0437\u0434\u0430\u0433 \u0431\u0430\u0439\u043d\u0430. \u0415\u0440 \u043d\u044c \u0430\u0436\u0438\u0433\u043b\u0430\u0430\u0434 \u0431\u0430\u0439\u0445\u0430\u0434 \u0436\u0438\u0440\u0438\u0439\u043d \u0436\u043e\u043b\u043e\u043e\u0447 \u0446\u0430\u0433\u0430\u0430\u0447\u043b\u0430\u0445 \u043c\u0430\u0433\u0430\u0434\u043b\u0430\u043b \u0431\u0430\u0433\u0430 \u0431\u0430\u0439\u0445 \u0436\u0438\u0448\u044d\u044d\u0442\u044d\u0439. \u0425\u0430\u0440\u0438\u043d \u0436\u043e\u043b\u043e\u043e\u0447 \u043d\u0430\u0440\u044b\u043d \u0430\u0445\u043b\u0430\u0433\u0447 \u044e\u043c \u0443\u0443 \u044f\u043c\u0430\u0440 \u043d\u044d\u0433\u044d\u043d \u0443\u0434\u0438\u0440\u0434\u0430\u0445 \u0442\u04e9\u0432\u0448\u0438\u043d\u0438\u0439 \u0430\u0436\u0438\u043b \u044d\u0440\u0445\u044d\u043b\u0434\u044d\u0433 \u0431\u043e\u043b \u0437\u0430\u0445 \u0437\u044d\u044d\u043b\u0434 \u0434\u0430\u0441\u0430\u043d \u0437\u043e\u0445\u0438\u0446\u043e\u0445 \u0447\u0430\u0434\u0432\u0430\u0440\u0442\u0430\u0439 \u0433\u044d\u0436 \u04af\u0437\u0434\u044d\u0433 \u044e\u043c \u0431\u0438\u043b\u044d\u044d. \u0422\u0438\u0439\u043c\u044d\u044d\u0441 \u0431\u0438\u0434 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440, \u043c\u0430\u0433\u0438\u0441\u0442\u0440, \u0434\u043e\u043a\u0442\u043e\u0440\u044b\u043d \u0437\u044d\u0440\u044d\u0433\u0442\u044d\u0439 \u0433\u044d\u0445 \u043c\u044d\u0442 \u0434\u044d\u044d\u0434 \u0431\u043e\u043b\u043e\u0432\u0441\u0440\u043e\u043b\u0442\u043e\u0439 \u0445\u04af\u043c\u04af\u04af\u0441\u0438\u0439\u0433 \u0441\u043e\u043d\u0433\u043e\u0445 \u0445\u04af\u0441\u044d\u043b\u0442\u044d\u0439 \u0431\u0430\u0439\u0433\u0430\u0430.<\/p>\n\n\n\n<p>\u0417\u0443\u0443\u0447\u043b\u0430\u043b\u044b\u043d \u04af\u043d\u044d \u0431\u043e\u043b\u043e\u043d \u0445\u04e9\u0440\u04e9\u043d\u0433\u0438\u0439\u043d \u0431\u0430\u0442\u0430\u043b\u0433\u0430\u0430 \u044f\u043c\u0430\u0440 \u0431\u0430\u0439\u0445 \u0445\u044d\u0440\u044d\u0433\u0442\u044d\u0439 \u0432\u044d? \u041c\u0430\u043d\u0430\u0439\u0445\u043d\u044b \u0445\u044d\u043b\u0434\u0433\u044d\u044d\u0440 \u0442\u0430\u043d\u0430\u0439 \u0431\u0430\u0439\u0433\u0443\u0443\u043b\u043b\u0430\u0433\u0430\u0430\u0440 \u0437\u0443\u0443\u0447\u043b\u0443\u0443\u043b\u0431\u0430\u043b &#8220;\u043d\u0430\u0439\u0434\u0432\u0430\u0440\u0442\u0430\u0439&#8221; \u0446\u0430\u0433\u0430\u0430\u0447\u043b\u0430\u043b\u044b\u043d \u044d\u0440\u0445 \u0430\u0432\u0447 \u0447\u0430\u0434\u0430\u0445 \u0443\u0443?<br>-\u041c\u0430\u043d\u0430\u0439 \u0431\u0430\u0439\u0433\u0443\u0443\u043b\u043b\u0430\u0433\u044b\u043d \u0437\u04af\u0433\u044d\u044d\u0441 99 \u0445\u0443\u0432\u0438\u0439\u043d \u0431\u0430\u0442\u0430\u043b\u0433\u0430\u0430 \u04e9\u0433\u043d\u04e9. \u0413\u044d\u0445\u0434\u044d\u044d \u0442\u0443\u0445\u0430\u0439\u043d \u0445\u04af\u043d\u044d\u044d\u0441 \u0448\u0430\u043b\u0442\u0433\u0430\u0430\u043b\u0430\u0445 \u0437\u04af\u0439\u043b\u04af\u04af\u0434 \u0431\u0430\u0439\u0433\u0430\u0430. \u0422\u0443\u0445\u0430\u0439\u043b\u0431\u0430\u043b \u0434\u0438\u043f\u043b\u043e\u043c, \u0431\u0430\u043d\u043a\u043d\u044b \u0431\u0430\u0442\u0430\u043b\u0433\u0430\u0430 \u0437\u044d\u0440\u044d\u0433 \u0445\u0443\u0443\u0440\u0430\u043c\u0447 \u0431\u0438\u0447\u0438\u0433 \u0431\u0430\u0440\u0438\u043c\u0442 \u04af\u0439\u043b\u0434\u0441\u044d\u043d \u0431\u0443\u044e\u0443 \u044d\u0440\u04af\u04af\u043b \u043c\u044d\u043d\u0434\u044d\u044d\u0440 \u0442\u044d\u043d\u0446\u044d\u0445\u0433\u04af\u0439 \u0442\u043e\u0445\u0438\u043e\u043b\u0434\u043e\u043b\u0434 \u044f\u0