3 \u0447\u0438\u0433\u043b\u044d\u043b\u044d\u044d\u0440 \u0442\u0443\u0441 \u0443\u043b\u0441\u0430\u0434 \u0431\u0430\u043a\u0430\u043b\u0430\u0432\u0440, \u043c\u0430\u0433\u0438\u0441\u0442\u0440, \u0434\u043e\u043a\u0442\u043e\u0440\/\u043f\u043e\u0441\u0442 \u0434\u043e\u043a\u0442\u043e\u0440\u044b\u043d \u0437\u044d\u0440\u044d\u0433\u0442 \u0441\u0443\u0440\u0430\u043b\u0446\u0430\u0445 \u0442\u044d\u0442\u0433\u044d\u043b\u044d\u0433\u0442 \u0445\u04e9\u0442\u04e9\u043b\u0431\u04e9\u0440 \u0437\u0430\u0440\u043b\u0430\u0433\u0434\u043b\u0430\u0430.<\/p>\n\n\n\n<p>\u0422\u0443\u0445\u0430\u0439\u043d \u0442\u044d\u0442\u0433\u044d\u043b\u0433\u0438\u0439\u0433 \u0441\u043e\u043d\u0438\u0440\u0445\u0441\u043e\u043d 18-30 \u0445\u04af\u0440\u0442\u044d\u043b\u0445 \u043d\u0430\u0441\u043d\u044b (\u0434\u043e\u043a\u0442\u043e\u0440\u044b\u043d \u0441\u0443\u0440\u0433\u0430\u043b\u0442\u0430\u0434 \u04e9\u0440\u0433\u04e9\u0434\u04e9\u043b \u0433\u0430\u0440\u0433\u0430\u0433\u0447 \u043d\u044c 45 \u0445\u04af\u0440\u0442\u044d\u043b\u0445 \u043d\u0430\u0441\u043d\u044b) \u0438\u0440\u0433\u044d\u043d \u042d\u043d\u044d\u0442\u0445\u044d\u0433\u0438\u0439\u043d \u0421\u043e\u0451\u043b\u044b\u043d \u0437\u04e9\u0432\u043b\u04e9\u043b (ICCR)-\u0438\u0439\u043d&nbsp;<a href=\"http:\/\/a2ascholarships.iccr.gov.in\/\" target=\"_blank\" rel=\"noreferrer noopener\">http:\/\/a2ascholarships.iccr.gov.in<\/a>&nbsp;\u043b\u0438\u043d\u043a \u0440\u0443\u0443 \u0445\u0430\u043d\u0434\u0430\u043d \u043e\u043d\u043b\u0430\u0439\u043d\u0430\u0430\u0440 \u0431\u04af\u0440\u0442\u0433\u04af\u04af\u043b\u044d\u044d\u0440\u044d\u0439. \u0425\u04e9\u0442\u04e9\u043b\u0431\u04e9\u0440 04 \u0434\u04af\u0433\u044d\u044d\u0440 \u0441\u0430\u0440\u044b\u043d 30 \u0445\u04af\u0440\u0442\u044d\u043b \u04af\u0440\u0433\u044d\u043b\u0436\u0438\u043b\u043d\u044d.<\/p>\n\n\n\n<p>\u0422\u044d\u0442\u0433\u044d\u043b\u044d\u0433\u0442\u044d\u0439 \u0445\u043e\u043b\u0431\u043e\u043e\u0442\u