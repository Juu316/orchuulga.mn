4d\u0441 \u0442\u0443\u0445\u0430\u0439\u043d \u0431\u0430\u0439\u0433\u0443\u0443\u043b\u043b\u0430\u0433\u044b\u0433 \u0431\u043e\u0434\u0438\u0442\u043e\u043e\u0440 \u043e\u0440\u0448\u0434\u043e\u0433 \u044d\u0441\u044d\u0445\u0438\u0439\u0433 \u0442\u043e\u0433\u0442\u043e\u043e\u0445 \u043d\u044c \u043d\u044d\u043d \u0442\u044d\u0440\u0433\u04af\u04af\u043d\u0434 \u0442\u0430\u0432\u0438\u0433\u0434\u0430\u0445 \u0448\u0430\u0430\u0440\u0434\u043b\u0430\u0433\u0430 \u044e\u043c. 3. \u0425\u044d\u0442 \u04af\u043d\u044d\u043c\u0448\u0438\u043b\u0433\u04af\u0439 \u0431\u0430\u0433\u0430 \u04af\u043d\u044d \u0430\u043c\u043b\u0430\u0445. \u0417\u0430\u0440\u0438\u043c \u0442\u043e\u0445\u0438\u043e\u043b\u0434\u043e\u043b\u0434 \u043d\u0430\u0439\u0434\u0432\u0430\u0440\u0433\u04af\u0439 \u0445\u04af\u043c\u04af\u04af\u0441 \u0442\u0430\u043d\u044b\u0433 \u0445\u044f\u043c\u0434 \u04af\u043d\u044d\u0442\u044d\u0439 \u04af\u0439\u043b\u0447\u0438\u043b\u0433\u044d\u044d \u0445\u0430\u0439\u0436 \u0431\u0430\u0439\u0433\u0430\u0430\u0433 \u0447\u0438\u043d\u044c \u043e\u043b\u0437\u043b\u043e\u043d \u0430\u0432\u0447 \u0431\u0430\u0439\u0433\u0430\u0430 \u043c\u04e9\u043d\u0433\u0438\u0439\u0433 \u0442\u0430\u043d\u044c \u0445\u0430\u043c\u0436 \u043e\u0434\u043e\u043d \u0430\u043b\u0433\u0430 \u0431\u043e\u043b\u043e\u0445 \u044d\u0440\u0441\u0434\u044d\u043b \u0443\u0447\u0438\u0440\u0447 \u0431\u043e\u043b\u0437\u043e\u0448\u0433\u04af\u0439. \u0422\u0438\u0439\u043c\u044d\u044d\u0441 \u0442\u0443\u0445\u0430\u0439\u043d \u0433\u0430\u0437\u0440\u0430\u0430\u0441 \u0433\u0430\u0440\u0433\u0430\u0441\u0430\u043d \u04af\u043d\u044d\u043b\u0433\u044d\u044d \u043d\u044c \u0445\u0430\u0440\u044c\u0446\u0430\u043d\u0433\u0443\u0439 \u0431\u043e\u0434\u0438\u0442\u043e\u0439 \u0431\u0430\u0439\u0445 \u0442\u0430\u043b \u0434\u044d\u044d\u0440 \u0430\u043d\u0445\u0430\u0430\u0440\u0430\u0445 \u0445\u044d\u0440\u044d\u0433\u0442\u044d\u0439. 4. \u0410\u0441\u0443\u0443\u