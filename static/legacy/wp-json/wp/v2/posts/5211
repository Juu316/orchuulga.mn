\u043d\u0435\u0441 \u0430\u044f\u043b\u0430\u043b\u044b\u043d \u043a\u0430\u0440\u0442 \u0431\u043e\u043b\u043e\u043d \u0441\u0443\u0440\u0430\u043b\u0446\u0430\u0445 \u043e\u0440\u0448\u0438\u043d \u0441\u0443\u0443\u0445 \u0437\u04e9\u0432\u0448\u04e9\u04e9\u0440\u04e9\u043b\u0442\u044d\u0439 \u0433\u0430\u0434\u0430\u0430\u0434\u044b\u043d \u043e\u044e\u0443\u0442\u043d\u0443\u0443\u0434\u044b\u0433 \u0425\u044f\u0442\u0430\u0434\u0430\u0434 \u043d\u044d\u0432\u0442\u0440\u044d\u0445\u0438\u0439\u0433 \u0437\u04e9\u0432\u0448\u04e9\u04e9\u0440\u043d\u04e9\u201c<\/p>\n\n\n\n<p>\u0425\u044f\u0442\u0430\u0434\u0430\u0434 \u0430\u043a\u0430\u0434\u0435\u043c\u0438\u043a \u0431\u043e\u043b\u043e\u0432\u0441\u0440\u043e\u043b \u044d\u0437\u044d\u043c\u0448\u0438\u0445 \u0443\u0440\u0442 \u0445\u0443\u0433\u0430\u0446\u0430\u0430\u043d\u044b \u043e\u044e\u0443\u0442\u043d\u0443\u0443\u0434 &#8220;\u0411\u041d\u0425\u0410\u0423 \u0434\u0430\u0445\u044c \u0433\u0430\u0434\u0430\u0430\u0434 \u043e\u044e\u0443\u0442\u043d\u0443\u0443\u0434\u0430\u0434 \u0437\u043e\u0440\u0438\u0443\u043b\u0441\u0430\u043d \u0432\u0438\u0437 \u043c\u044d\u0434\u04af\u04af\u043b\u044d\u0445 \u043c\u0430\u044f\u0433\u0442&#8221; (JW201 \u044d\u0441\u0432\u044d\u043b JW202 \u043c\u0430\u044f\u0433\u0442) \u0431\u043e\u043b\u043e\u043d \u0441\u0443\u0440\u0433\u0443\u0443\u043b\u044c\u0434 \u044d\u043b\u0441\u044d\u0445 \u0442\u0443\u0445\u0430\u0439 \u043c\u044d\u0434\u044d\u0433\u0434\u044d\u043b, \u044d\u0441\u0432\u044d\u043b \u0441\u0443\u0440\u0433\u0443\u0443\u043b\u044c\u0434\u0430\u0430 \u0431\u0443\u0446\u0430\u0436 \u043e\u0447\u043e\u043e\u0434 \u0441\u0443\u0440\u0430\u043b\u0446\u0430\u0445 \u0442\u043e\u0434\u043e\u0440\u0445\u043e\u0439\u043b\u043e\u043b\u0442\u0442\u043e\u0439 \u0431\u043e\u043b (X1) \u0432\u0438\u0437 \u043c\u044d\u0434\u04af\u04af\u043b\u044d\u0445 \u0431\u043e\u043b\u043e\u043c\u0436\u0442\u043e\u0439.<\/p>\n\n\n\n<p>\u0425\u04af\u0447\u0438\u043d\u0442\u044d\u0439 \u0441\u0443\u0440\u0430\u043b\u0446\u0430\u0445 (X1) \u0432\u0438\u0437 \u0431\u0443\u044e\u0443 \u0441\u0443\u0440\u0430\u043b\u0446\u0430\u0445 \u0442\u04e9\u0440\u043b\u0438\u0439\u043d \u043e\u0440\u0448\u0438\u043d \u0441\u0443\u0443\u0445 \u0437\u04e9\u0432\u0448\u04e9\u04e9\u0440\u04e9\u043b\u0442\u044d\u0439, \u0425\u044f\u0442\u0430\u0434\u0430\u0434 (180 \u0445\u043e\u043d\u043e\u0433\u043e\u043e\u0441 \u0434\u044d\u044d\u0448) \u043e\u0440\u0448\u0438\u043d \u0441\u0443\u0443\u0445, \u0442\u04e9\u0440\u04e9\u043b \u0442\u04e9\u0440\u04e9\u0433\u0441\u04e9\u0434\u0442\u044d\u0439\u0433\u044d\u044d \u0443\u0443\u043b\u0437\u0430\u0445 \u0433\u044d\u0436 \u0431\u0430\u0439\u0433\u0430\u0430 \u0433\u0430\u0434\u0430\u0430\u0434\u044b\u043d \u0438\u0440\u0433\u044d\u0434\u0438\u0439\u043d \u0433\u044d\u0440 \u0431\u04af\u043b\u0438\u0439\u043d \u0433\u0438\u0448\u04af\u04af\u0434 (\u044d\u0445\u043d\u044d\u0440, \u044d\u0446\u044d\u0433 \u044d\u0445, 18 \u043d\u0430\u0441 \u0445\u04af\u0440\u044d\u044d\u0433\u04af\u0439 \u0445\u04af\u04af\u0445\u044d\u0434, \u0445\u0430\u0434\u0430\u043c \u044d\u0446\u044d\u0433 \u044d\u0445) \u0431\u043e\u0433\u0438\u043d\u043e \u0445\u0443\u0433\u0430\u0446\u0430\u0430 (180 \u0445\u043e\u043d\u043e\u0433\u043e\u043e\u0441 \u0438\u043b\u04af\u04af\u0433\u04af\u0439) 180 \u0445\u043e\u043d\u043e\u0433), \u0445\u0443\u0432\u0438\u0439\u043d \u0430\u0441\u0443\u0443\u0434\u043b\u0430\u0430\u0440 (S1 \u044d\u0441\u0432\u044d\u043b S2 \u04af\u0433) \u0432\u0438\u0437 \u043c\u044d\u0434\u04af\u04af\u043b\u044d\u0445 \u0431\u043e\u043b\u043e\u043c\u0436\u0442\u043e\u0439.<\/p>\n\n\n\n<p>\u042d\u0445 \u0441\u0443\u0440\u0432\u0430\u043b\u0436: <a href=\"https:\/\/l.facebook.com\/l.php?u=http%3A%2F%2Fmn.china-embassy.gov.cn%2Fchn%2Flsfw%2Ftztx%2F202208%2Ft20220823_10749372.htm%3Ffbclid%3DIwAR3CI9SCvLBO3Itx2Psr1LaDZMTZBAMR7ruuyZnqV9xlOUoj96mGocdHvxU&amp;h=AT1S_aHYCElQWtFRcxQa7wZGNjoU4BMEHJeTwhk70JiDjYz3lG7vJ-wlMXpDXZ4F_MjR2xS4L